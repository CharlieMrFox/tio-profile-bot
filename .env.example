# Copy this file to ".env" and fill in your values.
# Never commit the real .env file to git.

DISCORD_TOKEN=your-bot-token-here
CLIENT_ID=your-application-client-id-here

# Optional: set this while testing so commands register instantly to one server
# instead of taking up to 1 hour to propagate globally.
GUILD_ID=your-test-server-id-here

# Optional: channel ID where the bot posts a fallback message if it can't DM
# a new member (e.g. their DMs are closed to server members). If left blank,
# the bot just logs the failed DM to the console instead.
FALLBACK_CHANNEL_ID=your-fallback-channel-id-here

# Optional: role ID granted automatically to members whose Test IO profile is
# found. Members who already hold this role are skipped on join (no re-check,
# no re-DM). The bot's own role must sit ABOVE this role in Server Settings →
# Roles, and the bot needs the "Manage Roles" permission.
VERIFIED_ROLE_ID=your-verified-tester-role-id-here
